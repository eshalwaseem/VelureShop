@model VelureShop.Models.Order
@{
    ViewBag.Title = "Order Confirmed";
    var items = (List<VelureShop.Models.OrderItem>)ViewBag.Items;
}

<div class="container py-5 text-center" style="max-width:600px;">
    <div style="font-size:54px;">&#9989;</div>
    <h1 class="fw-bold mt-3">Order Confirmed!</h1>
    <p class="text-muted">Thank you for shopping with VELURE. Your order <strong>#@Model.OrderID</strong> has been placed.</p>
    <div class="order-summary-box text-start mt-4">
        @foreach (var item in items)
        {
            <div class="d-flex justify-content-between mb-2">
                <span>@item.Quantity &times; @item.Product.Name</span>
                <span>PKR @item.LineTotal.ToString("N0")</span>
            </div>
        }
        <hr />
        <div class="d-flex justify-content-between mb-1"><span>Subtotal</span><span>PKR @Model.Subtotal.ToString("N0")</span></div>
        <div class="d-flex justify-content-between mb-1"><span>Shipping</span><span>@(Model.Shipping == 0 ? "Free" : "PKR " + Model.Shipping.ToString("N0"))</span></div>
        <div class="d-flex justify-content-between mb-3"><span>Tax</span><span>PKR @Model.Tax.ToString("N0")</span></div>
        <hr />
        <div class="d-flex justify-content-between fw-bold fs-5">
            <span>Total</span>
            <span>PKR @Model.Total.ToString("N0")</span>
        </div>
        <div class="text-muted mt-3" style="font-size:14px;">
            Payment Method: <strong>Cash on Delivery</strong><br />
            Status: <span class="status-pill status-@Model.Status">@Model.Status</span>
        </div>
    </div>
    <a href="@Url.Action("Index", "Home")" class="btn btn-dark mt-4">CONTINUE SHOPPING</a>
</div>


