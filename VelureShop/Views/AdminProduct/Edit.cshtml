@model VelureShop.Models.Product
@{
    ViewBag.Title = "Edit Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="bg-white rounded p-4" style="max-width:640px;">
    @using (Html.BeginForm("Edit", "AdminProduct", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.ProductID)

        <div class="mb-3">
            <label class="form-label">Product Name</label>
            @Html.TextBoxFor(m => m.Name, new { @class = "form-control", required = "required" })
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = 3 })
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Price (PKR)</label>
                @Html.TextBoxFor(m => m.Price, new { @class = "form-control", type = "number", step = "0.01", required = "required" })
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Stock Quantity</label>
                @Html.TextBoxFor(m => m.StockQty, new { @class = "form-control", type = "number", required = "required" })
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Category</label>
            @Html.DropDownListFor(m => m.CategoryID, (SelectList)ViewBag.CategoryID, new { @class = "form-control" })
        </div>
        <div class="mb-3">
            <label class="form-label">Image filename</label>
            @Html.TextBoxFor(m => m.ImagePath, new { @class = "form-control" })
            <div class="form-text">File should live at /Images/products/&lt;filename&gt;</div>
        </div>
        <div class="form-check mb-4">
            @Html.CheckBoxFor(m => m.IsActive)
            <label class="form-check-label">Active (visible in store)</label>
        </div>

        <button type="submit" class="btn btn-dark">UPDATE PRODUCT</button>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary ms-2">Cancel</a>
    }
</div>


