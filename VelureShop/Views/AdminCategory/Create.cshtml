
@model VelureShop.Models.Category
@{
    ViewBag.Title = "Add Category";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="bg-white rounded p-4" style="max-width:480px;">
    @using (Html.BeginForm("Create", "AdminCategory", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Category Name</label>
            @Html.TextBox("Name", null, new { @class = "form-control", required = "required", placeholder = "Dresses" })
        </div>
        <div class="mb-4">
            <label class="form-label">Gender</label>
            @Html.DropDownList("Gender", new List<SelectListItem>
       {
           new SelectListItem { Text = "Women", Value = "Women" },
           new SelectListItem { Text = "Men", Value = "Men" }
       }, "-- Select --", new { @class = "form-control" })
        </div>

        <button type="submit" class="btn btn-dark">SAVE CATEGORY</button>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary ms-2">Cancel</a>
    }
</div>

