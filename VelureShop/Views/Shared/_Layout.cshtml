@using System.Linq
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - VELURE | VelureShop</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
    /* ── Reset & Base ── */
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'Helvetica Neue', Arial, sans-serif;
        color: #1a1a1a;
        background: #fff;
    }

    a {
        color: inherit;
        text-decoration: none;
    }

    /* ── Header ── */
    .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: #fff;
        border-bottom: 1px solid #e8e8e4;
        padding: 16px 0;
    }

    .brand-logo {
        font-size: 22px;
        font-weight: 800;
        letter-spacing: .12em;
        color: #1a1a1a;
    }

    .main-nav {
        gap: 32px;
    }

        .main-nav a {
            font-size: 14px;
            letter-spacing: .06em;
            color: #444;
            transition: color .2s;
        }

            .main-nav a:hover, .main-nav a.active {
                color: #1a1a1a;
                border-bottom: 2px solid #1a1a1a;
            }

    .header-icons {
        gap: 18px;
        font-size: 20px;
    }

        .header-icons a {
            color: #1a1a1a;
        }

    .cart-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #2c3e34;
        color: #fff;
        border-radius: 50%;
        width: 18px;
        height: 18px;
        font-size: 11px;
        font-weight: 700;
        vertical-align: super;
        margin-left: 2px;
    }

    /* ── Hero ── */
    .hero {
        background: #f5f4f0;
        padding: 80px 0 72px;
    }

        .hero .hero-eyebrow {
            font-size: 12px;
            letter-spacing: .14em;
            color: #888;
            margin-bottom: 16px;
        }

        .hero h1 {
            font-size: clamp(36px, 5vw, 64px);
            line-height: 1.1;
            font-weight: 300;
            margin-bottom: 20px;
        }

        .hero p {
            font-size: 16px;
            color: #666;
            max-width: 480px;
            margin-bottom: 32px;
        }

    .btn-mono {
        display: inline-block;
        background: #1a1a1a;
        color: #fff;
        padding: 13px 32px;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: .1em;
        border: none;
        cursor: pointer;
        transition: background .2s;
    }

        .btn-mono:hover {
            background: #2c3e34;
            color: #fff;
        }

    /* ── Perks Strip ── */
    .perks-strip {
        background: #fafaf8;
        border-top: 1px solid #e8e8e4;
        border-bottom: 1px solid #e8e8e4;
        padding: 28px 0;
    }

    .perk-item {
        display: flex;
        align-items: center;
        gap: 14px;
        font-size: 14px;
    }

        .perk-item strong {
            display: block;
        }

        .perk-item span {
            color: #888;
            font-size: 13px;
        }

    /* ── Section Headings ── */
    .section-heading {
        font-size: 22px;
        font-weight: 700;
        letter-spacing: -.01em;
    }

    .view-all-link {
        font-size: 13px;
        color: #888;
        border-bottom: 1px solid #ccc;
    }

    /* ── Product Card ── */
    .product-card {
        margin-bottom: 32px;
    }

    .product-image-wrap {
        position: relative;
        background: #f0efeb;
        aspect-ratio: 3/4;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
    }

        .product-image-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .4s ease;
        }

    .product-card:hover .product-image-wrap img {
        transform: scale(1.04);
    }

    .placeholder-icon {
        width: 60px;
        height: 60px;
        color: #bbb;
    }

    .product-title {
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 3px;
    }

    .product-meta {
        font-size: 12px;
        color: #888;
        margin-bottom: 4px;
    }

    .product-price {
        font-size: 14px;
        font-weight: 700;
    }

    .badge-new, .badge-sale {
        position: absolute;
        top: 10px;
        left: 10px;
        z-index: 2;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .08em;
        padding: 4px 8px;
        border-radius: 2px;
    }

    .badge-new {
        background: #2c3e34;
        color: #fff;
    }

    .badge-sale {
        background: #c0392b;
        color: #fff;
    }

    .quick-add-bar {
        width: 100%;
        padding: 11px;
        background: #1a1a1a;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .08em;
        border: none;
        cursor: pointer;
        transform: translateY(100%);
        transition: transform .25s ease;
    }

    .product-image-wrap:hover .quick-add-bar {
        transform: translateY(0);
    }

    .quick-add-bar:disabled {
        background: #888;
        cursor: default;
    }

    /* ── Promo Banner ── */
    .promo-banner {
        background: #2c3e34;
        color: #fff;
        padding: 40px 48px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 20px;
    }

        .promo-banner .btn-mono {
            background: #fff;
            color: #1a1a1a;
        }

            .promo-banner .btn-mono:hover {
                background: #f0efeb;
            }

    /* ── Auth Card ── */
    .auth-card {
        max-width: 420px;
        margin: 60px auto;
        background: #fff;
        border: 1px solid #e8e8e4;
        border-radius: 6px;
        padding: 40px;
    }

    /* ── Cart ── */
    .cart-line-image {
        width: 72px;
        height: 88px;
        background: #f0efeb;
        border-radius: 2px;
        flex-shrink: 0;
    }

    .qty-control {
        display: flex;
        align-items: center;
        border: 1px solid #ddd;
        border-radius: 3px;
        width: fit-content;
    }

        .qty-control button {
            background: none;
            border: none;
            padding: 6px 12px;
            font-size: 16px;
            cursor: pointer;
        }

        .qty-control input {
            width: 36px;
            text-align: center;
            border: none;
            border-left: 1px solid #ddd;
            border-right: 1px solid #ddd;
            font-size: 14px;
            padding: 6px 0;
        }

    .order-summary-box {
        background: #fafaf8;
        border: 1px solid #e8e8e4;
        border-radius: 6px;
        padding: 28px;
    }

    /* ── Checkout ── */
    .checkout-step-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #1a1a1a;
        color: #fff;
        font-size: 13px;
        font-weight: 700;
    }

    .form-section-number {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        background: #1a1a1a;
        color: #fff;
        border-radius: 50%;
        font-size: 12px;
        font-weight: 700;
        margin-right: 8px;
    }

    .payment-option {
        border: 2px solid #e8e8e4;
        border-radius: 6px;
        padding: 16px 20px;
        cursor: pointer;
    }

        .payment-option.selected {
            border-color: #2c3e34;
            background: #f5f9f7;
        }

    /* ── Shop Listing ── */
    .filter-sidebar {
        font-size: 14px;
    }

        .filter-sidebar h6 {
            font-weight: 700;
            letter-spacing: .06em;
            margin-bottom: 12px;
        }

    .filter-count {
        color: #aaa;
        font-size: 12px;
        margin-left: 4px;
    }

    /* ── Status Pills ── */
    .status-pill {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: .04em;
    }

    .status-Pending {
        background: #fff3cd;
        color: #856404;
    }

    .status-Processing {
        background: #cfe2ff;
        color: #084298;
    }

    .status-Shipped {
        background: #d1ecf1;
        color: #0c5460;
    }

    .status-Delivered {
        background: #d1e7dd;
        color: #0a3622;
    }

    .status-Cancelled {
        background: #f8d7da;
        color: #842029;
    }

    /* ── Admin Panel ── */
    body:has(.admin-sidebar) {
        background: #fafaf8;
    }

    .admin-sidebar {
        background: #2c3e34;
        min-height: 100vh;
        padding: 32px 0;
        position: sticky;
        top: 0;
        display: flex;
        flex-direction: column;
    }

        .admin-sidebar a {
            display: block;
            padding: 11px 26px;
            color: rgba(255,255,255,.75);
            font-size: 14px;
            transition: all .15s;
        }

            .admin-sidebar a:hover, .admin-sidebar a.active {
                background: rgba(255,255,255,.1);
                color: #fff;
            }

    .admin-stat-card {
        background: #fff;
        border: 1px solid #e8e8e4;
        border-radius: 6px;
        padding: 24px 28px;
    }

    .stat-value {
        font-size: 36px;
        font-weight: 800;
        margin-top: 6px;
    }

    /* ── Footer ── */
    .site-footer {
        background: #1a1a1a;
        color: #fff;
        padding: 60px 0 32px;
        margin-top: 60px;
    }
        .site-footer .brand-logo {
            color: #fff;
        }
        .site-footer .text-muted {
            color: #aaa !important;
        }

    .footer-col h6 {
        font-size: 12px;
        letter-spacing: .1em;
        color: #aaa;
        margin-bottom: 14px;
    }

    .footer-col a {
        display: block;
        color: #ccc;
        font-size: 14px;
        margin-bottom: 8px;
    }

        .footer-col a:hover {
            color: #fff;
        }

     .social-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border: 1px solid #444;
        border-radius: 50%;
        margin-right: 8px;
        font-size: 13px;
        cursor: pointer;
    }

    </style >
    @RenderSection("styles", required: false)
</head>
<body>
    
    <header class="site-header">
        <div class="container d-flex align-items-center justify-content-between">
            <a href="@Url.Action("Index", "Home")" class="brand-logo">VELURE</a>
            <nav class="main-nav d-none d-md-flex">
                <a href="@Url.Action("Index", "Home")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "Home" ? "active" : "")">Home</a>
                <a href="@Url.Action("Women", "Shop")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Women" ? "active" : "")">Women</a>
                <a href="@Url.Action("Men", "Shop")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Men" ? "active" : "")">Men</a>
            </nav>

            <div class="header-icons d-flex align-items-center">
                <a href="#" title="Search"><i class="fas fa-search"></i></a>
                @if (Session["UserID"] != null)
                {
                    <div class="dropdown" style="display:inline-block;">
                        <a href="#" id="accountDropdown" data-bs-toggle="dropdown" title="Account"><i class="fas fa-user"></i></a>                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><span class="dropdown-item-text text-muted">Hi, @Session["Name"]</span></li>
                            @if (Session["Role"] != null && Session["Role"].ToString() == "Admin")
                            {
                                <li><a class="dropdown-item" href="@Url.Action("Index", "AdminDashboard")">Admin Panel</a></li>
                            }
                            <li><a class="dropdown-item" href="@Url.Action("Logout", "Account")">Logout</a></li>
                        </ul>
                    </div>
                }else
                {<a href="@Url.Action("Login", "Account")" title="Account"><i class="fas fa-user"></i></a>

                }
                <a href="@Url.Action("Index", "Cart")" title="Cart">
                    <i class="fas fa-bag-shopping"></i>
                    @{ var cartCount = ViewBag.CartCount ?? 0; }
                    @if ((int)cartCount > 0)
                    {
                        <span class="cart-badge">@cartCount</span>
                    }
                </a>
            </div>
        </div>
    </header>

    @if (TempData["Error"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-danger">@TempData["Error"]</div>
        </div>
    }
    @RenderBody()
    <footer class="site-footer">
        <div class="container">
            <div class="row">
                <div class="col-md-3 mb-4">
                    <div class="brand-logo mb-3">VELURE</div>
                    <p class="text-muted" style="font-size:14px;">
                        Considered essentials for everyday dressing. Designed in small batches, made to last beyond the season.
                    </p>
                    <div>
                        <span class="social-icon"><i class="fab fa-instagram"></i></span>
                        <span class="social-icon"><i class="fab fa-facebook-f"></i></span>
                        <span class="social-icon"><i class="fab fa-x-twitter"></i></span>
                    </div>
                </div>
                <div class="col-md-2 ms-auto footer-col mb-4">
                    <h6>Shop</h6>
                    <a href="@Url.Action("Women", "Shop")">Women</a>
                    <a href="@Url.Action("Men", "Shop")">Men</a>
                    <a href="@Url.Action("Index", "Home")">New In</a>
                    <a href="@Url.Action("Index", "Home")">Bestsellers</a>
                    <a href="@Url.Action("Index", "Home")">Sale</a>
                </div>
                
                </div>
            </div>
            
          
        </footer>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    function quickAdd(form, e) {
        e.preventDefault();
        $.post(form.action, $(form).serialize(), function (res) {
            if (res.success) {
                var badge = $('.cart-badge');
                if (res.cartCount > 0) {
                    if (badge.length) badge.text(res.cartCount);
                    else $('a[title="Cart"]').append('<span class="cart-badge">' + res.cartCount + '</span>');
                }
            } else if (res.redirect) {
                window.location.href = res.redirect;
            }
        });
        return false;
    }
</script>
    @RenderSection("scripts", required: false)
</body>
</html>