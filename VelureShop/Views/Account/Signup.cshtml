@{
    ViewBag.Title = "Signup";
}

<div class="auth-card">
    <h2 class="fw-bold mb-1">Create your account</h2>
    <p class="text-muted mb-4">Join VELURE for free shipping &amp; member pricing</p>
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form action="@Url.Action("Signup", "Account")" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label class="form-label">Full Name</label>
            <input type="text" name="fullName" class="form-control" placeholder="Ayesha Khan" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Email Address</label>
            <input type="email" name="email" class="form-control" placeholder="you@example.com" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Phone Number</label>
            <input type="text" name="phone" class="form-control" placeholder="+92 300 1234567" />
        </div>
        <div class="mb-4">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" placeholder="••••••••" required />
        </div>
        <button type="submit" class="btn btn-dark w-100">CREATE ACCOUNT</button>
    </form>
    <p class="text-center text-muted mt-4 mb-0" style="font-size:14px;">
        Already have an account? <a href="@Url.Action("Login", "Account")" class="text-decoration-underline">Log in</a>
    </p>
</div>
