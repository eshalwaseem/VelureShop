@model VelureShop.Models.Product
<div class="product-card">
    <div class="product-image-wrap">
        @if (Model.StockQty <= 0) { 
            <span class="badge-sale" style="background:#6b6b66;">SOLD OUT</span>
            }
            else if (Model.ProductID % 5 == 0)
            {
            <span class="badge-new">NEW</span>
            }
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Model.DisplayImage" alt="@Model.Name" onerror="this.style.display='none'" />
            }
            else
            {
                <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="3" y="3" width="18" height="18" rx="2" />
                    <circle cx="8.5" cy="8.5" r="1.5" />
                    <path d="M21 15l-5-5L5 21" />
                </svg>
            }
        <form action="@Url.Action("Add", "Cart")" method="post" style="position:absolute;bottom:0;left:0;right:0;" onsubmit="return quickAdd(this, event)">
            @Html.AntiForgeryToken()
            <input type="hidden" name="productId" value="@Model.ProductID" />
            <button type="submit" class="quick-add-bar" @(Model.StockQty <= 0 ? "disabled" : "")>
                @(Model.StockQty <= 0 ? "SOLD OUT" : "+ QUICK ADD")
            </button>
        </form>
        </div>
        <a href="@Url.Action("Details", "Shop", new { id = Model.ProductID })">
            <div class="product-title">@Model.Name</div>
        </a>
        <div class="product-meta">@(Model.Category != null ? Model.Category.Name : "")</div>
        <div class="product-price">PKR @Model.Price.ToString("N0")</div>
    </div>

