@model List<VelureShop.Models.Category>
@{
    ViewBag.Title = "Categories";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-end mb-3">
    <a href="@Url.Action("Create")" class="btn btn-dark">+ ADD CATEGORY</a>
</div>
<div class="table-responsive bg-white rounded p-3">
    <table class="table align-middle mb-0">
        <thead>
            <tr class="text-muted" style="font-size:13px;">
                <th>NAME</th>
                <th>GENDER</th>
                <th>PRODUCTS</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.Name</td>
                    <td>@c.Gender</td>
                    <td>@c.Products.Count</td>
                    <td>
                        <a href="@Url.Action("Edit", new { id = c.CategoryID })" class="me-3">Edit</a>
                        <a href="@Url.Action("Delete", new { id = c.CategoryID })" class="text-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

