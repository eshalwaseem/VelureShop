@model VelureShop.Models.Product
    @{
        ViewBag.Title = Model.Name;
    }

    <div class="container mt-4 mb-5">
    <div class="text-muted mb-4" style="font-size:14px;">
        <a href="@Url.Action("Index", "Home")">Home</a> /
        <a href="@Url.Action(Model.Category.Gender, "Shop")">@Model.Category.Gender</a> /
        <strong>@Model.Name</strong>
    </div>
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="product-image-wrap" style="aspect-ratio:1/1;">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.DisplayImage" alt="@Model.Name" />
                }
                else
                {
                    <svg class="placeholder-icon" style="width:80px;height:80px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="3" width="18" height="18" rx="2" />
                        <circle cx="8.5" cy="8.5" r="1.5" />
                        <path d="M21 15l-5-5L5 21" />
                    </svg>
                }
            </div>
        </div>
        <div class="col-md-6">
            <div class="text-muted mb-1">@Model.Category.Name</div>
            <h1 class="fw-bold mb-2">@Model.Name</h1>
            <<div class="fs-4 fw-bold mb-3">PKR @Model.Price.ToString("N0")</div>
            <p class="text-muted mb-4">@Model.Description</p>
            @if (Model.StockQty > 0)
            {
                <div class="text-success mb-3" style="font-size:14px;">&#10003; In Stock (@Model.StockQty available)</div>
<form action="@Url.Action("Add", "Cart")" method="post" class="d-flex gap-2" onsubmit="return quickAdd(this, event)">                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.ProductID" />
                    <input type="number" name="quantity" value="1" min="1" max="@Model.StockQty" class="form-control" style="width:90px;" />
                    <button type="submit" class="btn btn-dark flex-grow-1">ADD TO CART</button>
                </form>
            }
            else
            {
                <div class="text-danger mb-3" style="font-size:14px;">Currently sold out</div>
                <button class="btn btn-dark" disabled>SOLD OUT</button>
            }
            <hr class="my-4" />
            <div style="font-size:14px;" class="text-muted">
                <div><strong>Easy 30-day returns</strong> on unworn items</div>
            </div>
        </div>
    </div>

    @{
        var related = (List<VelureShop.Models.Product>)ViewBag.Related;
    }
    @if (related != null && related.Count > 0)
    {
        <h2 class="section-heading mt-5 mb-4">You may also like</h2>
        <div class="row">
            @foreach (var p in related)
            {
                <div class="col-6 col-md-3">
                    @Html.Partial("_ProductCard", p)
                </div>
            }
        </div>
    }
</div>

