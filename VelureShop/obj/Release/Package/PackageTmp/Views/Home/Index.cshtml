
    @{
    ViewBag.Title = "Home";
    var womenBestsellers = (List<VelureShop.Models.Product>)ViewBag.WomenBestsellers;
    var menBestsellers = (List<VelureShop.Models.Product>)ViewBag.MenBestsellers;

}
<section class="hero">
    <div class="container">
        <div class="hero-eyebrow">AUTUMN EDIT &mdash; 01</div>
        <h1>Considered basics,<br /><strong>made to last.</strong></h1>
        <p>Clean silhouettes and natural fabrics for everyday dressing &mdash; for her and for him.</p>
        <a href="@Url.Action("Women", "Shop")" class="btn btn-mono">SHOP NOW</a>
    </div>
</section>
<section class="perks-strip">
    <div class="container">
        <div class="row">
            <div class="col-md-4 perk-item justify-content-center">
                <i class="fas fa-location-dot" style="font-size:22px;"></i>
                <div>
                    <strong>Nationwide Delivery</strong>
                    <span>Delivering across Pakistan</span>
                </div>
            </div>
            <div class="col-md-4 perk-item justify-content-center">
                <i class="fas fa-rotate-left" style="font-size:22px;"></i>
                <div>
                    <strong>Easy Returns</strong>
                    <span>30-day return policy</span>
                </div>
            </div>
            <div class="col-md-4 perk-item justify-content-center">
                <i class="fas fa-shield-halved" style="font-size:22px;"></i>
                <div>
                    <strong>Secure Payments</strong>
                    <span>100% protected checkout</span>
                </div>
            </div>
        </div>
    </div>
</section>
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-heading">Bestsellers &mdash; Women</h2>
        <a href="@Url.Action("Women", "Shop")" class="view-all-link">View All &rsaquo;</a>
    </div>
    <div class="row">
        @if (womenBestsellers != null)
{
    foreach (var product in womenBestsellers)
    {
        <div class="col-6 col-md-3">
            @Html.Partial("_ProductCard", product)
        </div>
    }
}
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4 mt-5">
        <h2 class="section-heading">Bestsellers &mdash; Men</h2>
        <a href="@Url.Action("Men", "Shop")" class="view-all-link">View All &rsaquo;</a>
    </div>
    <div class="row mb-5">
        @if (womenBestsellers != null)
{
    foreach (var product in menBestsellers)
    {
        <div class="col-6 col-md-3">
            @Html.Partial("_ProductCard", product)
        </div>
    }
}
    </div>
    <div class="promo-banner mb-5">
        <div>
            <h3>End of Season &mdash; <strong>up to 40% off</strong></h3>
            <p class="mb-0" style="opacity:.8;">Selected styles. While stocks last.</p>
        </div>
        <a href="@Url.Action("Women", "Shop")" class="btn btn-mono">SHOP THE SALE</a>
    </div>
</div>

